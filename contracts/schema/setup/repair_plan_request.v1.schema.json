{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/repair_plan_request.v1.schema.json",
  "title": "Public Repair Plan Request",
  "type": "object",
  "required": ["schema", "request_id", "plan_id", "install_id", "created_at", "archive"],
  "properties": {
    "schema": { "const": "usk.repair_plan_request.v1" },
    "request_id": { "$ref": "#/$defs/id" },
    "plan_id": { "$ref": "#/$defs/id" },
    "install_id": { "$ref": "#/$defs/id" },
    "created_at": { "type": "string", "format": "date-time" },
    "archive": { "$ref": "#/$defs/archive" }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "archive": {
      "type": "object",
      "required": ["path", "format", "expected_sha256", "strip_prefix"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 32768 },
        "format": { "const": "zip" },
        "expected_sha256": { "$ref": "#/$defs/sha256" },
        "strip_prefix": { "type": "string", "maxLength": 4096 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
