{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/operation_plan.v1.schema.json",
  "title": "Digest-Bound Managed Lifecycle Operation Plan",
  "type": "object",
  "required": [
    "schema",
    "plan_id",
    "plan_digest",
    "operation",
    "status",
    "created_at",
    "install_id",
    "input_identity",
    "roots",
    "effects",
    "target_snapshots",
    "unknown_file_policy",
    "revalidation"
  ],
  "properties": {
    "schema": { "const": "usk.operation_plan.v1" },
    "plan_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "plan_digest": { "$ref": "#/$defs/sha256" },
    "operation": { "enum": ["repair", "move", "uninstall", "recovery"] },
    "status": { "const": "planned" },
    "created_at": { "type": "string", "format": "date-time" },
    "install_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "input_identity": {
      "type": "object",
      "required": ["installed_state_digest", "ownership_manifest_digest", "policy_digest", "provider_revision"],
      "properties": {
        "installed_state_digest": { "$ref": "#/$defs/sha256" },
        "ownership_manifest_digest": { "$ref": "#/$defs/sha256" },
        "recipe_digest": { "$ref": "#/$defs/sha256" },
        "source_digest": { "$ref": "#/$defs/sha256" },
        "policy_digest": { "$ref": "#/$defs/sha256" },
        "provider_revision": { "type": "string", "minLength": 1, "maxLength": 256 }
      },
      "additionalProperties": false
    },
    "roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "root", "classification"],
        "properties": {
          "role": { "enum": ["current", "destination", "staging", "setup_state", "audit"] },
          "root": { "type": "string", "minLength": 1, "maxLength": 32768 },
          "classification": { "enum": ["managed_install", "operator_selected_owned_target", "setup_owned", "audit_owned"] },
          "must_not_exist": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["effect_id", "kind", "root_role", "relative_path", "ownership_required"],
        "properties": {
          "effect_id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["copy_owned_file", "replace_owned_file", "delete_owned_file", "create_owned_directory", "retain_path", "write_state", "write_journal", "write_audit"] },
          "root_role": { "enum": ["current", "destination", "staging", "setup_state", "audit"] },
          "relative_path": { "type": "string", "minLength": 1, "maxLength": 4096 },
          "ownership_required": { "const": true },
          "expected_sha256": { "$ref": "#/$defs/sha256" }
        },
        "additionalProperties": false
      }
    },
    "target_snapshots": {
      "type": "object",
      "required": ["pre_target_digest"],
      "properties": { "pre_target_digest": { "$ref": "#/$defs/sha256" } },
      "additionalProperties": false
    },
    "unknown_file_policy": { "const": "retain_and_report" },
    "revalidation": {
      "type": "object",
      "required": ["immediately_before_apply", "invalidate_on"],
      "properties": {
        "immediately_before_apply": { "const": true },
        "invalidate_on": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": { "enum": ["source", "recipe", "target", "installed_state", "ownership_manifest", "policy", "provider_revision"] }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
