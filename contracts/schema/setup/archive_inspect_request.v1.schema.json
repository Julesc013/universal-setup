{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/archive_inspect_request.v1.schema.json",
  "title": "Bounded Local Archive Inspection Request",
  "type": "object",
  "required": ["schema", "archive_path", "archive_format", "budgets"],
  "properties": {
    "schema": { "const": "usk.archive_inspect_request.v1" },
    "archive_path": { "type": "string", "minLength": 1, "maxLength": 32768 },
    "archive_format": { "const": "zip" },
    "budgets": {
      "type": "object",
      "required": ["max_entries", "max_uncompressed_bytes", "max_entry_bytes", "max_depth", "max_ratio", "max_elapsed_ms"],
      "properties": {
        "max_entries": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "max_uncompressed_bytes": { "type": "integer", "minimum": 1, "maximum": 1099511627776 },
        "max_entry_bytes": { "type": "integer", "minimum": 1, "maximum": 274877906944 },
        "max_depth": { "type": "integer", "minimum": 1, "maximum": 256 },
        "max_ratio": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "max_elapsed_ms": { "type": "integer", "minimum": 1, "maximum": 120000 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
