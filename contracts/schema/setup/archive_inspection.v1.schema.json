{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/archive_inspection.v1.schema.json",
  "title": "Deterministic Local Archive Inspection",
  "type": "object",
  "required": ["schema", "inspection_id", "entry_set_digest", "status", "inspected_at", "normalization_policy", "source", "entries", "totals", "problems"],
  "properties": {
    "schema": { "const": "usk.archive_inspection.v1" },
    "inspection_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "entry_set_digest": { "$ref": "#/$defs/sha256" },
    "status": { "const": "pass" },
    "inspected_at": { "type": "string", "format": "date-time" },
    "normalization_policy": { "const": "ascii_case_insensitive_v1" },
    "source": {
      "type": "object",
      "required": ["schema", "source_id", "kind", "path", "archive_format", "size_bytes", "sha256", "filesystem_identity", "inspected_at", "stable_read", "budgets"],
      "properties": {
        "schema": { "const": "usk.source.v1" },
        "source_id": { "type": "string", "minLength": 1 },
        "kind": { "const": "local_archive" },
        "path": { "type": "string", "minLength": 1 },
        "archive_format": { "const": "zip" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "filesystem_identity": {
          "type": "object",
          "required": ["volume_id", "file_id", "size_bytes", "modified_time_ns"],
          "properties": {
            "volume_id": { "type": "string", "minLength": 1 },
            "file_id": { "type": "string", "minLength": 1 },
            "size_bytes": { "type": "integer", "minimum": 0 },
            "modified_time_ns": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "inspected_at": { "type": "string", "format": "date-time" },
        "stable_read": { "const": true },
        "budgets": { "$ref": "#/$defs/budgets" }
      },
      "additionalProperties": false
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["normalized_path", "entry_type", "compressed_size", "uncompressed_size", "compression_method", "local_header_offset"],
        "properties": {
          "normalized_path": { "type": "string", "minLength": 1, "maxLength": 4096 },
          "entry_type": { "enum": ["file", "directory"] },
          "compressed_size": { "type": "integer", "minimum": 0 },
          "uncompressed_size": { "type": "integer", "minimum": 0 },
          "compression_method": { "enum": ["stored", "deflate"] },
          "local_header_offset": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "totals": {
      "type": "object",
      "required": ["file_count", "directory_count", "compressed_bytes", "uncompressed_bytes"],
      "properties": {
        "file_count": { "type": "integer", "minimum": 0 },
        "directory_count": { "type": "integer", "minimum": 0 },
        "compressed_bytes": { "type": "integer", "minimum": 0 },
        "uncompressed_bytes": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "problems": { "type": "array", "maxItems": 0 },
    "additionalProperties": false
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "budgets": {
      "type": "object",
      "required": ["max_entries", "max_uncompressed_bytes", "max_entry_bytes", "max_depth", "max_ratio", "max_elapsed_ms"],
      "properties": {
        "max_entries": { "type": "integer", "minimum": 1 },
        "max_uncompressed_bytes": { "type": "integer", "minimum": 1 },
        "max_entry_bytes": { "type": "integer", "minimum": 1 },
        "max_depth": { "type": "integer", "minimum": 1 },
        "max_ratio": { "type": "integer", "minimum": 1 },
        "max_elapsed_ms": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
