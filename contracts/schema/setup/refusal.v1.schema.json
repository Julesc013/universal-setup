{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/refusal.v1.schema.json",
  "title": "Setup Refusal",
  "type": "object",
  "required": ["schema", "refusal_id", "operation", "code", "reason", "recoverable", "recorded_at"],
  "properties": {
    "schema": { "const": "usk.refusal.v1" },
    "refusal_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "operation": { "enum": ["inspect", "plan", "install_local", "verify", "repair", "move", "uninstall", "recovery", "audit"] },
    "code": {
      "enum": [
        "ownership_denied",
        "unsafe_source",
        "unsafe_target",
        "existing_target",
        "source_changed",
        "recipe_changed",
        "target_changed",
        "installed_state_changed",
        "ownership_manifest_changed",
        "policy_changed",
        "provider_revision_changed",
        "plan_expired",
        "plan_digest_mismatch",
        "archive_entry_unsafe",
        "archive_budget_exceeded",
        "archive_collision",
        "unknown_files_present",
        "changed_owned_files_require_review",
        "ambiguous_replacement",
        "network_forbidden",
        "registry_forbidden",
        "elevation_forbidden",
        "package_manager_forbidden",
        "installer_execution_forbidden",
        "unsupported_platform",
        "invalid_recipe",
        "missing_artifact",
        "recovery_required",
        "live_target_acceptance_required",
        "target_class_forbidden",
        "target_not_explicit",
        "target_outside_acceptance_root",
        "target_not_empty",
        "target_filesystem_not_local",
        "target_path_redirected",
        "target_mount_redirected",
        "target_root_excluded",
        "target_space_insufficient",
        "source_target_same_object",
        "target_effects_incomplete",
        "target_identity_unproven"
      ]
    },
    "reason": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "recoverable": { "type": "boolean" },
    "recorded_at": { "type": "string", "format": "date-time" },
    "plan_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "transaction_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "policy_digest": { "$ref": "#/$defs/sha256" },
    "suggested_next_command": { "type": "string", "minLength": 1, "maxLength": 256 }
  },
  "$defs": { "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
  "additionalProperties": false
}
