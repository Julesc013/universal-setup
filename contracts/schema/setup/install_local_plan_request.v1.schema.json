{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/install_local_plan_request.v1.schema.json",
  "title": "Public Local Install Plan Request",
  "type": "object",
  "required": ["schema", "request_id", "created_at", "install_id", "archive", "target", "recipe"],
  "properties": {
    "schema": { "const": "usk.install_local_plan_request.v1" },
    "request_id": { "$ref": "#/$defs/id" },
    "created_at": { "type": "string", "format": "date-time" },
    "install_id": { "$ref": "#/$defs/id" },
    "archive": { "$ref": "#/$defs/archive" },
    "target": { "$ref": "#/$defs/target" },
    "recipe": { "$ref": "#/$defs/recipe" }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "relative_path": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "budgets": {
      "type": "object",
      "required": ["max_entries", "max_uncompressed_bytes", "max_entry_bytes", "max_depth", "max_ratio", "max_elapsed_ms"],
      "properties": {
        "max_entries": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "max_uncompressed_bytes": { "type": "integer", "minimum": 1, "maximum": 1099511627776 },
        "max_entry_bytes": { "type": "integer", "minimum": 1, "maximum": 274877906944 },
        "max_depth": { "type": "integer", "minimum": 1, "maximum": 256 },
        "max_ratio": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "max_elapsed_ms": { "type": "integer", "minimum": 1, "maximum": 120000 }
      },
      "additionalProperties": false
    },
    "archive": {
      "type": "object",
      "required": ["path", "format", "expected_sha256", "strip_prefix", "budgets"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 32768 },
        "format": { "const": "zip" },
        "expected_sha256": { "$ref": "#/$defs/sha256" },
        "strip_prefix": { "type": "string", "maxLength": 4096 },
        "budgets": { "$ref": "#/$defs/budgets" }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["root", "class"],
      "properties": {
        "root": { "type": "string", "minLength": 1, "maxLength": 32768 },
        "class": { "enum": ["operator_acceptance", "managed_portable"] }
      },
      "additionalProperties": false
    },
    "entrypoint": {
      "type": "object",
      "required": ["entrypoint_id", "relative_path", "kind"],
      "properties": {
        "entrypoint_id": { "$ref": "#/$defs/id" },
        "relative_path": { "$ref": "#/$defs/relative_path" },
        "kind": { "enum": ["application", "tool", "server"] }
      },
      "additionalProperties": false
    },
    "recipe": {
      "type": "object",
      "required": ["product_id", "product_version", "recipe_digest", "provider_revision", "components", "entrypoints"],
      "properties": {
        "product_id": { "$ref": "#/$defs/id" },
        "product_version": { "type": "string", "minLength": 1, "maxLength": 256 },
        "recipe_digest": { "$ref": "#/$defs/sha256" },
        "provider_revision": { "$ref": "#/$defs/id" },
        "components": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
        "entrypoints": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/entrypoint" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
