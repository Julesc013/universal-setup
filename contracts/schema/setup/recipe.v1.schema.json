{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/recipe.v1.schema.json",
  "title": "Declarative Portable Setup Recipe",
  "type": "object",
  "required": [
    "schema",
    "recipe_id",
    "recipe_version",
    "product",
    "source",
    "target_scope",
    "required_paths",
    "forbidden_paths",
    "components",
    "entrypoints",
    "post_stage_verification",
    "capability_probes",
    "installed_state_schema"
  ],
  "properties": {
    "schema": { "const": "usk.recipe.v1" },
    "recipe_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "recipe_version": { "type": "string", "minLength": 1, "maxLength": 64 },
    "product": {
      "type": "object",
      "required": ["product_id", "version"],
      "properties": {
        "product_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "version": { "type": "string", "minLength": 1, "maxLength": 128 }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["kind", "expected_sha256", "archive_format", "strip_prefix"],
      "properties": {
        "kind": { "const": "local_archive" },
        "expected_sha256": { "$ref": "#/$defs/sha256" },
        "archive_format": { "enum": ["zip", "tar", "tar_gzip"] },
        "strip_prefix": {
          "type": "object",
          "required": ["mode"],
          "properties": {
            "mode": { "enum": ["none", "single_root", "exact"] },
            "value": { "$ref": "#/$defs/relative_path" }
          },
          "allOf": [
            {
              "if": { "properties": { "mode": { "const": "exact" } } },
              "then": { "required": ["value"] },
              "else": { "not": { "required": ["value"] } }
            }
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "target_scope": { "const": "portable" },
    "required_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/relative_path" }
    },
    "forbidden_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/relative_path" }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["component_id", "required", "paths"],
        "properties": {
          "component_id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "required": { "type": "boolean" },
          "paths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "$ref": "#/$defs/relative_path" }
          }
        },
        "additionalProperties": false
      }
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["entrypoint_id", "relative_path", "kind"],
        "properties": {
          "entrypoint_id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "relative_path": { "$ref": "#/$defs/relative_path" },
          "kind": { "enum": ["application", "tool", "server"] }
        },
        "additionalProperties": false
      }
    },
    "post_stage_verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check_id", "kind", "relative_path"],
        "properties": {
          "check_id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "kind": { "enum": ["path_exists", "regular_file", "directory", "file_sha256"] },
          "relative_path": { "$ref": "#/$defs/relative_path" },
          "expected_sha256": { "$ref": "#/$defs/sha256" }
        },
        "allOf": [
          {
            "if": { "properties": { "kind": { "const": "file_sha256" } } },
            "then": { "required": ["expected_sha256"] },
            "else": { "not": { "required": ["expected_sha256"] } }
          }
        ],
        "additionalProperties": false
      }
    },
    "capability_probes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["probe_id", "kind", "relative_path"],
        "properties": {
          "probe_id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "kind": { "enum": ["path_exists", "file_version_resource", "text_file_pattern"] },
          "relative_path": { "$ref": "#/$defs/relative_path" },
          "pattern": { "type": "string", "minLength": 1, "maxLength": 1024 }
        },
        "additionalProperties": false
      }
    },
    "installed_state_schema": { "const": "usk.installed_state.v1" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^[^/\\\\].*"
    }
  },
  "additionalProperties": false
}
