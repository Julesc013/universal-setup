{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/installed_state.v1.schema.json",
  "title": "Managed Portable Installed State",
  "type": "object",
  "required": [
    "schema",
    "install_id",
    "product_id",
    "product_version",
    "recipe_digest",
    "source_archive_digest",
    "target_root",
    "target_scope",
    "component_selection",
    "ownership_manifest_ref",
    "ownership_manifest_digest",
    "entrypoints",
    "setup_abi",
    "transaction_id",
    "created_at",
    "last_verification",
    "audit_chain_id",
    "lifecycle_status"
  ],
  "properties": {
    "schema": { "const": "usk.installed_state.v1" },
    "install_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "product_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "product_version": { "type": "string", "minLength": 1, "maxLength": 128 },
    "recipe_digest": { "$ref": "#/$defs/sha256" },
    "source_archive_digest": { "$ref": "#/$defs/sha256" },
    "target_root": { "type": "string", "minLength": 1, "maxLength": 32768 },
    "target_scope": { "const": "portable" },
    "component_selection": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },
    "ownership_manifest_ref": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "ownership_manifest_digest": { "$ref": "#/$defs/sha256" },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["entrypoint_id", "relative_path", "kind"],
        "properties": {
          "entrypoint_id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "relative_path": { "type": "string", "minLength": 1, "maxLength": 4096 },
          "kind": { "enum": ["application", "tool", "server"] }
        },
        "additionalProperties": false
      }
    },
    "setup_abi": {
      "type": "object",
      "required": ["major", "minor", "provider_revision"],
      "properties": {
        "major": { "type": "integer", "minimum": 1 },
        "minor": { "type": "integer", "minimum": 0 },
        "provider_revision": { "type": "string", "minLength": 1, "maxLength": 256 }
      },
      "additionalProperties": false
    },
    "transaction_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "created_at": { "type": "string", "format": "date-time" },
    "last_verification": {
      "type": "object",
      "required": ["report_id", "report_digest", "status", "verified_at"],
      "properties": {
        "report_id": { "type": "string", "minLength": 1 },
        "report_digest": { "$ref": "#/$defs/sha256" },
        "status": { "enum": ["pass", "warn", "fail"] },
        "verified_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "audit_chain_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "lifecycle_status": { "enum": ["installed", "verified", "repair_required", "move_pending_acceptance", "uninstall_blocked", "recovery_required", "retired"] }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
