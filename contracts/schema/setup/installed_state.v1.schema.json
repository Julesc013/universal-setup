{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/installed_state.v1.schema.json",
  "title": "Installed State",
  "type": "object",
  "required": [
    "schema",
    "install_id",
    "product_id",
    "version",
    "root",
    "ownership",
    "state",
    "components",
    "audit_log_ref"
  ],
  "properties": {
    "schema": { "const": "usk.installed_state.v1" },
    "install_id": { "type": "string", "minLength": 1 },
    "product_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "root": { "type": "string", "minLength": 1 },
    "ownership": {
      "type": "string",
      "enum": ["managed", "foreign_owned", "imported", "adopted", "staged"]
    },
    "state": {
      "type": "string",
      "enum": ["planned", "installed", "partial", "verified", "uninstalled", "refused", "error"]
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component_id", "version", "path"],
        "properties": {
          "component_id": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "last_transaction_id": { "type": "string" },
    "audit_log_ref": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
