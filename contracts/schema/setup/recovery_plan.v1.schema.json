{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/recovery_plan.v1.schema.json",
  "title": "Digest-Bound Public Recovery Plan",
  "type": "object",
  "required": ["schema", "plan_id", "plan_digest", "status", "created_at", "install_id", "transaction_id", "journal_digest", "operation", "observed_state", "available_actions", "effects", "revalidation"],
  "properties": {
    "schema": { "const": "usk.recovery_plan.v1" },
    "plan_id": { "$ref": "#/$defs/id" },
    "plan_digest": { "$ref": "#/$defs/sha256" },
    "status": { "const": "planned" },
    "created_at": { "type": "string", "format": "date-time" },
    "install_id": { "$ref": "#/$defs/id" },
    "transaction_id": { "$ref": "#/$defs/id" },
    "journal_digest": { "$ref": "#/$defs/sha256" },
    "operation": { "enum": ["install_local", "repair", "move", "uninstall"] },
    "observed_state": { "$ref": "#/$defs/state" },
    "available_actions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["resume", "rollback", "retain_for_operator", "abandon"] }
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "root_class", "relative_path"],
        "properties": {
          "kind": { "enum": ["resume_transition", "delete_staged_path", "retain_path", "write_state", "write_audit"] },
          "root_class": { "enum": ["owned_target", "staging", "setup_state", "audit"] },
          "relative_path": { "type": "string", "minLength": 1, "maxLength": 4096 }
        },
        "additionalProperties": false
      }
    },
    "revalidation": {
      "type": "object",
      "required": ["immediately_before_apply", "invalidate_on"],
      "properties": {
        "immediately_before_apply": { "const": true },
        "invalidate_on": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["journal", "staging", "target", "policy"] }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "state": { "enum": ["created", "validated", "planned", "staging", "staged", "verified", "committing", "committed", "completed", "refused", "failed", "recovery_required", "rolled_back", "abandoned_by_operator"] }
  },
  "additionalProperties": false
}
