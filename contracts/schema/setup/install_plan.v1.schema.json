{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/install_plan.v1.schema.json",
  "title": "Digest-Bound Local Portable Install Plan",
  "type": "object",
  "required": [
    "schema",
    "plan_id",
    "plan_digest",
    "operation",
    "status",
    "created_at",
    "input_identity",
    "source",
    "target",
    "component_selection",
    "planned_entries",
    "totals",
    "effects",
    "revalidation",
    "refusal_policy"
  ],
  "properties": {
    "schema": { "const": "usk.install_plan.v1" },
    "plan_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "plan_digest": { "$ref": "#/$defs/sha256" },
    "operation": { "const": "install_local" },
    "status": { "const": "planned" },
    "created_at": { "type": "string", "format": "date-time" },
    "input_identity": { "$ref": "#/$defs/input_identity" },
    "source": {
      "type": "object",
      "required": ["source_id", "path", "sha256", "size_bytes", "filesystem_identity_digest", "path_identity_digest"],
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "filesystem_identity_digest": { "$ref": "#/$defs/sha256" },
        "path_identity_digest": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["root", "scope", "must_not_exist", "volume_id", "classification", "pre_snapshot_digest", "identity_digest", "path_identity_digest", "filesystem"],
      "properties": {
        "root": { "type": "string", "minLength": 1, "maxLength": 32768 },
        "scope": { "const": "portable" },
        "must_not_exist": { "const": true },
        "volume_id": { "type": "string", "minLength": 1 },
        "classification": { "const": "operator_selected_owned_target" },
        "pre_snapshot_digest": { "$ref": "#/$defs/sha256" },
        "identity_digest": { "$ref": "#/$defs/sha256" },
        "path_identity_digest": { "$ref": "#/$defs/sha256" },
        "filesystem": {
          "type": "object",
          "required": ["identity_digest", "kind", "capabilities"],
          "properties": {
            "identity_digest": { "$ref": "#/$defs/sha256" },
            "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
            "capabilities": {
              "type": "object",
              "required": ["local", "stable_ancestors", "no_mount_redirection", "no_replace_commit"],
              "properties": {
                "local": { "const": true },
                "stable_ancestors": { "const": true },
                "no_mount_redirection": { "const": true },
                "no_replace_commit": { "const": true }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "component_selection": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },
    "planned_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relative_path", "entry_type", "size_bytes"],
        "properties": {
          "relative_path": { "$ref": "#/$defs/relative_path" },
          "entry_type": { "enum": ["file", "directory"] },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "$ref": "#/$defs/sha256" }
        },
        "additionalProperties": false
      }
    },
    "totals": {
      "type": "object",
      "required": ["file_count", "directory_count", "uncompressed_bytes"],
      "properties": {
        "file_count": { "type": "integer", "minimum": 0 },
        "directory_count": { "type": "integer", "minimum": 0 },
        "uncompressed_bytes": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/effect" }
    },
    "revalidation": {
      "type": "object",
      "required": ["immediately_before_apply", "invalidate_on"],
      "properties": {
        "immediately_before_apply": { "const": true },
        "invalidate_on": {
          "type": "array",
          "uniqueItems": true,
          "contains": { "const": "source" },
          "items": { "enum": ["source", "recipe", "target", "policy", "provider_revision"] }
        }
      },
      "additionalProperties": false
    },
    "refusal_policy": { "$ref": "#/$defs/refusal_policy" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "relative_path": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "input_identity": {
      "type": "object",
      "required": ["recipe_digest", "source_digest", "policy_digest", "provider_revision"],
      "properties": {
        "recipe_digest": { "$ref": "#/$defs/sha256" },
        "source_digest": { "$ref": "#/$defs/sha256" },
        "policy_digest": { "$ref": "#/$defs/sha256" },
        "provider_revision": { "type": "string", "minLength": 1, "maxLength": 256 }
      },
      "additionalProperties": false
    },
    "effect": {
      "type": "object",
      "required": ["effect_id", "kind", "root_class", "relative_path"],
      "properties": {
        "effect_id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["create_directory", "write_file", "write_installed_state", "write_journal", "write_audit"] },
        "root_class": { "enum": ["owned_target", "setup_state", "staging", "audit"] },
        "relative_path": { "$ref": "#/$defs/relative_path" }
      },
      "additionalProperties": false
    },
    "refusal_policy": {
      "type": "object",
      "required": ["refuse_network", "refuse_registry", "refuse_elevation", "refuse_package_manager", "refuse_installer_execution", "refuse_existing_target"],
      "properties": {
        "refuse_network": { "const": true },
        "refuse_registry": { "const": true },
        "refuse_elevation": { "const": true },
        "refuse_package_manager": { "const": true },
        "refuse_installer_execution": { "const": true },
        "refuse_existing_target": { "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
