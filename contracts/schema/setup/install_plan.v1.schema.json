{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/universal-setup/contracts/schema/setup/install_plan.v1.schema.json",
  "title": "Install Plan",
  "type": "object",
  "required": [
    "schema",
    "plan_id",
    "operation",
    "dry_run",
    "product_id",
    "target",
    "ownership",
    "steps",
    "refusal_policy"
  ],
  "properties": {
    "schema": { "const": "usk.install_plan.v1" },
    "plan_id": { "type": "string", "minLength": 1 },
    "operation": {
      "type": "string",
      "enum": ["install_local", "verify", "repair", "uninstall", "adopt", "audit"]
    },
    "dry_run": { "type": "boolean" },
    "product_id": { "type": "string", "minLength": 1 },
    "target": {
      "type": "object",
      "required": ["root"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "ownership": {
      "type": "object",
      "required": ["kind", "may_mutate"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["managed", "foreign_owned", "imported", "adopted", "staged"]
        },
        "may_mutate": { "type": "boolean" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "action", "path", "rollback_required"],
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "action": {
            "type": "string",
            "enum": ["create_dir", "copy_file", "write_state", "verify_file", "delete_file", "remove_dir", "audit"]
          },
          "path": { "type": "string", "minLength": 1 },
          "rollback_required": { "type": "boolean" },
          "sha256": { "type": "string" },
          "source_ref": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "refusal_policy": {
      "type": "object",
      "required": ["refuse_network", "refuse_registry", "refuse_package_manager", "refuse_product_specific_installer"],
      "properties": {
        "refuse_network": { "const": true },
        "refuse_registry": { "const": true },
        "refuse_package_manager": { "const": true },
        "refuse_product_specific_installer": { "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
